<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- App header card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="32dp"
                android:gravity="center"
                android:background="#0069FF">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@mipmap/ic_launcher_round" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="DocScanner"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Scan. Store. Share."
                    android:textSize="13sp"
                    android:textColor="#AACCFF" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- App Info card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ℹ  Thông tin ứng dụng"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="4dp" />

                <!-- Version -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Phiên bản"
                        android:textSize="15sp" android:textColor="#1A1A2E" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="1.0.0" android:textColor="#0069FF" android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                <!-- Build -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Build"
                        android:textSize="15sp" android:textColor="#1A1A2E" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="#20260415" android:textColor="#888888" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                <!-- Min Android -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Android tối thiểu"
                        android:textSize="15sp" android:textColor="#1A1A2E" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Android 7.0 (API 24)" android:textColor="#888888" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                <!-- Release date -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Ngày phát hành"
                        android:textSize="15sp" android:textColor="#1A1A2E" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="15/04/2026" android:textColor="#888888" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                <!-- Package -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Package"
                        android:textSize="15sp" android:textColor="#1A1A2E" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="com.example.docscanner" android:textColor="#888888"
                        android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Developer card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👨‍💻  Nhà phát triển"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="4dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Tác giả"
                        android:textSize="15sp" android:textColor="#1A1A2E" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Nhóm 11" android:textColor="#0069FF" android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Trường"
                        android:textSize="15sp" android:textColor="#1A1A2E" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ĐH Giao thông vận tải" android:textColor="#888888" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Email liên hệ"
                        android:textSize="15sp" android:textColor="#1A1A2E" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="viettungpham113@gmail.com" android:textColor="#0069FF" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Description card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋  Mô tả ứng dụng"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DocScanner là ứng dụng chụp và quản lý tài liệu thông minh. Cho phép người dùng scan tài liệu, lưu trữ lên Cloud và chia sẻ dễ dàng.\n\nỨng dụng sử dụng Firebase Authentication để bảo mật tài khoản, CameraX để chụp ảnh chất lượng cao, và backend CodeIgniter 3 để quản lý dữ liệu."
                    android:textSize="14sp"
                    android:textColor="#444444"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Open source libraries -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📄  Thư viện mã nguồn mở"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Firebase SDK — Apache 2.0\n• CameraX — Apache 2.0\n• Retrofit2 — Apache 2.0\n• OkHttp3 — Apache 2.0\n• iText7 — AGPL / Commercial\n• uCrop — Apache 2.0"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:lineSpacingMultiplier="1.6" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
